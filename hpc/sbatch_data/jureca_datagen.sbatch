#!/bin/bash
#SBATCH -p {partition}
#SBATCH --time={time_limit}
#SBATCH --nodes {num_nodes}
#SBATCH --gpus-per-node=4
#SBATCH --gres=gpu:4
#SBATCH --ntasks-per-node 1
#SBATCH --cpus-per-task={cpus_per_node}
#SBATCH --account {account}
#SBATCH --output={experiments_dir}/logs/%x_%j.out
#SBATCH --job-name={job_name}
#SBATCH --mail-type=END,TIME_LIMIT,FAIL
#SBATCH --mail-user=bf996@nyu.edu

# set -eo pipefail
# set -x

# =============================================================================
# Create conda activation script for Ray worker environment consistency
# This ensures spawned processes (Ray actors, multiprocessing workers) get
# the same environment as the main process.
# =============================================================================
echo "=== Setting up Conda Activation Script for Ray Workers ==="
CONDA_ENV_PATH="/p/scratch/laionize/raj3/vllm_sandboxes"
CONDA_PYTHON_PATH="/p/scratch/laionize/raj3/vllm_sandboxes/bin"
ACTIVATE_D="$CONDA_ENV_PATH/etc/conda/activate.d"
ACTIVATION_SCRIPT="$ACTIVATE_D/vllm_ray_env.sh"

mkdir -p "$ACTIVATE_D"

# Detect libcuda.so path for Triton
TRITON_LIBCUDA_PATH=""
for candidate in \
    "/usr/lib64/libcuda.so.1" \
    "/usr/lib64/libcuda.so" \
    "/usr/local/cuda/lib64/stubs/libcuda.so" \
    "/opt/nvidia/lib64/libcuda.so.1"; do
    if [ -f "$candidate" ]; then
        TRITON_LIBCUDA_PATH="$candidate"
        break
    fi
done

# Write the activation script
cat > "$ACTIVATION_SCRIPT" << 'ACTIVATE_EOF'
#!/bin/bash
# =============================================================================
# vLLM Ray Worker Environment Setup
# Auto-generated by vista_datagen.sbatch
# This script runs on conda activate to ensure Ray actors get consistent env
# =============================================================================

# Triton CUDA driver detection
if [ -z "${TRITON_LIBCUDA_PATH:-}" ]; then
    for _candidate in \
        "/usr/lib64/libcuda.so.1" \
        "/usr/lib64/libcuda.so" \
        "/usr/local/cuda/lib64/stubs/libcuda.so" \
        "/opt/nvidia/lib64/libcuda.so.1"; do
        if [ -f "$_candidate" ]; then
            export TRITON_LIBCUDA_PATH="$_candidate"
            break
        fi
    done
fi

# Ensure CUDA driver directory is in LD_LIBRARY_PATH
if [ -n "${TRITON_LIBCUDA_PATH:-}" ]; then
    _cuda_driver_dir=$(dirname "$TRITON_LIBCUDA_PATH")
    if [[ ":${LD_LIBRARY_PATH:-}:" != *":$_cuda_driver_dir:"* ]]; then
        export LD_LIBRARY_PATH="$_cuda_driver_dir:${LD_LIBRARY_PATH:-}"
    fi
fi

# GCC/Triton compiler settings (needed for JIT compilation)
if [ -z "${TRITON_CC:-}" ]; then
    if [ -x "/home1/apps/gcc/15.1.0/bin/gcc" ]; then
        export TRITON_CC="/home1/apps/gcc/15.1.0/bin/gcc"
    elif command -v gcc &>/dev/null; then
        export TRITON_CC=$(command -v gcc)
    fi
fi

# Ensure GCC libraries are available
_gcc_lib="/home1/apps/gcc/15.1.0/lib64"
if [ -d "$_gcc_lib" ] && [[ ":${LD_LIBRARY_PATH:-}:" != *":$_gcc_lib:"* ]]; then
    export LD_LIBRARY_PATH="$_gcc_lib:${LD_LIBRARY_PATH:-}"
fi

# Ensure GCC is in PATH
_gcc_bin="/home1/apps/gcc/15.1.0/bin"
if [ -d "$_gcc_bin" ] && [[ ":${PATH:-}:" != *":$_gcc_bin:"* ]]; then
    export PATH="$_gcc_bin:${PATH:-}"
fi

# LD_PRELOAD for C++ stdlib compatibility
_libstdcpp="/home1/apps/gcc/15.1.0/lib64/libstdc++.so.6"
if [ -f "$_libstdcpp" ] && [[ ":${LD_PRELOAD:-}:" != *":$_libstdcpp:"* ]]; then
    export LD_PRELOAD="$_libstdcpp${LD_PRELOAD:+:$LD_PRELOAD}"
fi
ACTIVATE_EOF

chmod +x "$ACTIVATION_SCRIPT"
echo "  Created activation script: $ACTIVATION_SCRIPT"
echo "  TRITON_LIBCUDA_PATH will be: ${TRITON_LIBCUDA_PATH:-<not found>}"

# Now activate conda (which will source our new script)
source /p/project1/ccstdl/nezhurina1/miniconda/miniconda/bin/activate /p/scratch/laionize/raj3/vllm_sandboxes
export PYTHONNOUSERSITE=1
unset PYTHONPATH

# Function to setup proxy
setup_proxy() {
    local proxy_host="${1:-10.14.0.53}"  # Default proxy host, can be overridden
    local proxy_port="${2:-1080}"        # Default proxy port, can be overridden
    
    export LD_LIBRARY_PATH=/p/scratch/laionize/raj3/vllm_sandboxes/lib:$LD_LIBRARY_PATH
    
    echo "=== Setting up proxy access ==="
    local PROXY_HOST="$proxy_host"
    local PROXY_PORT="$proxy_port"
    
    # Verify proxy is reachable
    if nc -zv -w 5 ${PROXY_HOST} ${PROXY_PORT} 2>&1 | grep -q Connected; then
        echo "✓ Proxy reachable at ${PROXY_HOST}:${PROXY_PORT}"
    else
        echo "✗ ERROR: Cannot reach proxy at ${PROXY_HOST}:${PROXY_PORT}"
        echo "  Start proxy on login node first:"
        echo "  ssh -D 10.14.0.53:1080 -f -N -i ~/.ssh/docker jrlogin05i"
        return 1
    fi
    
    # Test proxy connection BEFORE setting LD_PRELOAD
    echo "Testing proxy connection..."
    if curl -s --max-time 10 --socks5 ${PROXY_HOST}:${PROXY_PORT} https://api.openai.com > /dev/null 2>&1; then
        echo "✓ Proxy connection successful"
    else
        echo "⚠ Proxy test failed (continuing anyway)"
    fi
    
    # Create proxychains config
    export PROXYCHAINS_CONF_FILE="/tmp/proxychains_${SLURM_JOB_ID:-$$}.conf"
    
    cat > "$PROXYCHAINS_CONF_FILE" << EOF
strict_chain
proxy_dns
remote_dns_subnet 224
tcp_read_time_out 15000
tcp_connect_time_out 8000
localnet 10.0.0.0/255.0.0.0
localnet 127.0.0.0/255.0.0.0
localnet 192.168.0.0/255.255.0.0
[ProxyList]
socks5 ${PROXY_HOST} ${PROXY_PORT}
EOF
    
    echo "✓ Proxychains config created"
    
    # NOW set LD_PRELOAD for proxychains (AFTER the test)
    export LD_PRELOAD="/p/scratch/laionize/raj3/vllm_sandboxes/lib/libproxychains.so.4${LD_PRELOAD:+:$LD_PRELOAD}"
    
    echo "==========================================="
    export HF_HUB_OFFLINE=0
    export HF_DATASETS_OFFLINE=0
    export TRANSFORMERS_OFFLINE=0
}

# Verify the activation script worked
echo "=== Post-Activation Environment Check ==="
echo "  TRITON_CC=${TRITON_CC:-<not set>}"
echo "  TRITON_LIBCUDA_PATH=${TRITON_LIBCUDA_PATH:-<not set>}"
echo "  LD_PRELOAD=${LD_PRELOAD:-<not set>}"
echo "  GCC in PATH: $(which gcc 2>/dev/null || echo '<not found>')"
echo "  libcuda.so exists: $([ -f "${TRITON_LIBCUDA_PATH:-/nonexistent}" ] && echo 'yes' || echo 'no')"

# Log GPU visibility for debugging
echo "  CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-<not set>}"
echo "  nvidia-smi GPU count: $(nvidia-smi -L 2>/dev/null | wc -l || echo 'nvidia-smi not available')"
echo "==========================================="

# Source environment variables
echo $DCFT
source "$DCFT/hpc/dotenv/jureca.env"
source "/p/scratch/laionize/raj3/keys.env"

# Set HF cache
export HF_HUB_OFFLINE=1
export HF_DATASETS_OFFLINE=1
export TRANSFORMERS_OFFLINE=1
export PYTHONFAULTHANDLER=1
export NCCL_TIMEOUT=1800  # 30 minutes
export NCCL_IB_TIMEOUT=23  # InfiniBand timeout

# Change to project directory
cd "$DCFT"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

# Build environment export strings - include TRITON_LIBCUDA_PATH for spawned processes
TRITON_LIBCUDA_EXPORT=""
if [ -n "${TRITON_LIBCUDA_PATH:-}" ]; then
    TRITON_LIBCUDA_EXPORT=",TRITON_LIBCUDA_PATH=$TRITON_LIBCUDA_PATH"
fi
export SRUN_EXPORT_ENV="ALL,TRITON_CC=$TRITON_CC,LD_LIBRARY_PATH=$LD_LIBRARY_PATH,PATH=$PATH,LD_PRELOAD=$LD_PRELOAD,HF_HOME=$HF_HOME,PYTHONPATH=$PYTHONPATH${TRITON_LIBCUDA_EXPORT}"

# For Ray workers (space-separated for env command)
RAY_ENV_VARS="TRITON_CC=$TRITON_CC LD_LIBRARY_PATH=$LD_LIBRARY_PATH PATH=$PATH LD_PRELOAD=$LD_PRELOAD HF_HOME=$HF_HOME PYTHONPATH=$PYTHONPATH"
if [ -n "${TRITON_LIBCUDA_PATH:-}" ]; then
    RAY_ENV_VARS="$RAY_ENV_VARS TRITON_LIBCUDA_PATH=$TRITON_LIBCUDA_PATH"
fi

BACKEND="${DATAGEN_BACKEND:-vllm}"

# Data generation parameters (set via environment)
GENERATE_SCRIPT="${DATAGEN_SCRIPT}"
ENDPOINT_JSON="${DATAGEN_ENDPOINT_JSON:-$DCFT/vllm_endpoint.json}"
TARGET_REPO="${DATAGEN_TARGET_REPO:-}"
INPUT_DIR="${DATAGEN_INPUT_DIR:-}"
EXTRA_ARGS="${DATAGEN_EXTRA_ARGS:-}"
ENGINE="${DATAGEN_ENGINE:-}"
REQUIRE_ENDPOINT="${DATAGEN_REQUIRE_ENDPOINT:-0}"
OUTPUT_DIR="${DATAGEN_OUTPUT_DIR:-}"
STAGE="${DATAGEN_STAGE:-tasks}"
WAIT_FOR_ENDPOINT="${DATAGEN_WAIT_FOR_ENDPOINT:-0}"
CONFIG_PATH="${DATAGEN_CONFIG_PATH:?DATAGEN_CONFIG_PATH is required}"
TASK_TYPE="${DATAGEN_TASK_TYPE:-}"

echo "=== Data Generation Configuration ==="
echo "Backend: $BACKEND"
echo "Generate Script: $GENERATE_SCRIPT"
echo "Endpoint JSON: ${ENDPOINT_JSON:-<none>}"
echo "Target Repo: $TARGET_REPO"
echo "Input Dir: $INPUT_DIR"
echo "Extra Args: $EXTRA_ARGS"
echo "Engine Hint: ${ENGINE:-<from config>}"
echo "Config Path: $CONFIG_PATH"
echo "Output Dir: ${OUTPUT_DIR:-<none>}"
echo "Task Type: ${TASK_TYPE:-<none>}"
echo "Stage: $STAGE"
echo "======================================"

if [ -n "$OUTPUT_DIR" ]; then
    mkdir -p "$OUTPUT_DIR"
fi

# Build command
# CMD=("$CONDA_PYTHON_PATH/python3" "$GENERATE_SCRIPT" --stage "$STAGE" --engine-config "$CONFIG_PATH" --trace-harbor-config /p/scratch/laionize/raj3/OpenThoughts-Agent/hpc/harbor_yaml/trace_16concurrency_ctx32k.yaml)
CMD=("$CONDA_PYTHON_PATH/python3" "$GENERATE_SCRIPT" --stage "$STAGE" --engine-config "$CONFIG_PATH" --trace-harbor-config /p/scratch/laionize/raj3/OpenThoughts-Agent/hpc/harbor_yaml/trace_4concurrency_ctx32k.yaml)

if [ -n "$TARGET_REPO" ]; then
    CMD+=(--target-repo "$TARGET_REPO")
fi

if [ -n "$INPUT_DIR" ]; then
    CMD+=(--input-dir "$INPUT_DIR")
fi

if [ -n "$OUTPUT_DIR" ]; then
    CMD+=(--output-dir "$OUTPUT_DIR")
fi

if [ -n "$TASK_TYPE" ]; then
    CMD+=(--task-type "$TASK_TYPE")
fi

if [ -n "$EXTRA_ARGS" ]; then
    # shellcheck disable=SC2206
    EXTRA_ARR=($EXTRA_ARGS)
    CMD+=("${EXTRA_ARR[@]}")
fi

run_datagen_stream() {
    echo "Running: ${CMD[*]}"
    echo "======================================"
    "${CMD[@]}" 2>&1 | while IFS= read -r line; do
        echo "$line"
        if echo "$line" | grep -q "Healthcheck passed"; then
            echo "[$(date)] ✓ Endpoint healthy"
        elif echo "$line" | grep -q "Healthcheck FAILED"; then
            echo "[$(date)] ✗ Endpoint health check FAILED"
            echo "ERROR: Healthcheck failed - terminating job"
            exit 1
        fi
    done
    return "${PIPESTATUS[0]}"
}

if [ "$BACKEND" != "ray" ]; then
    if [ "$REQUIRE_ENDPOINT" = "1" ] && [ "$WAIT_FOR_ENDPOINT" = "1" ]; then
        if [ -z "$ENDPOINT_JSON" ]; then
            echo "ERROR: Endpoint required but path is empty"
            exit 1
        fi

        echo "Waiting for endpoint JSON file..."
        MAX_WAIT=600
        WAIT_COUNT=0
        while [ ! -f "$ENDPOINT_JSON" ] && [ $WAIT_COUNT -lt $MAX_WAIT ]; do
            sleep 5
            WAIT_COUNT=$((WAIT_COUNT + 5))
            if [ $((WAIT_COUNT % 30)) -eq 0 ]; then
                echo "Still waiting for $ENDPOINT_JSON... (${WAIT_COUNT}s elapsed)"
            fi
        done

        if [ ! -f "$ENDPOINT_JSON" ]; then
            echo "ERROR: Endpoint JSON not found after ${MAX_WAIT}s: $ENDPOINT_JSON"
            exit 1
        fi

        echo "✓ Endpoint JSON found: $ENDPOINT_JSON"
        cat "$ENDPOINT_JSON"
    else
        echo "Skipping endpoint wait (engine=$ENGINE, wait_flag=${DATAGEN_WAIT_FOR_ENDPOINT:-0})"
    fi

    setup_proxy
    run_datagen_stream
    EXIT_CODE=$?
else
    echo "=== Starting Ray-backed vLLM cluster ==="
    nodes=$(scontrol show hostnames "$SLURM_JOB_NODELIST")
    nodes_array=($nodes)
    head_node=${nodes_array[0]}
    head_node_i="${head_node}i" # for JSC
    
    head_node_ip="$(nslookup "$head_node_i" | grep -oP '(?<=Address: ).*')"

    RAY_PORT="${DATAGEN_RAY_PORT:-6379}"
    API_PORT="${DATAGEN_API_PORT:-8000}"
    TP_SIZE="${DATAGEN_TENSOR_PARALLEL_SIZE:-1}"
    DP_SIZE="${DATAGEN_DATA_PARALLEL_SIZE:-1}"
    GPUS_PER_NODE="${DATAGEN_GPUS_PER_NODE:-0}"
    export DATAGEN_GPUS_PER_NODE="$GPUS_PER_NODE"
    NUM_NODES=$SLURM_JOB_NUM_NODES
    TOTAL_GPUS=$(python3 - <<'PY'
import os
print(int(os.environ.get("SLURM_JOB_NUM_NODES", "1")) * int(os.environ.get("DATAGEN_GPUS_PER_NODE", "0")))
PY
)

    ip_head="${head_node_ip}:${RAY_PORT}"
    export RAY_ADDRESS="$ip_head"

    ray_pids=()

    start_ray_node() {
        local node_name=$1
        local start_cmd=$2
        srun --export="$SRUN_EXPORT_ENV" --nodes=1 --ntasks=1 -w "$node_name" bash -c "env $RAY_ENV_VARS printenv TRITON_CC TRITON_LIBCUDA_PATH LD_LIBRARY_PATH PATH LD_PRELOAD; env $RAY_ENV_VARS $start_cmd" &
        ray_pids+=($!)
    }

    ORIG_LD_PRELOAD="$LD_PRELOAD"
    unset LD_PRELOAD

    head_cmd="$CONDA_PYTHON_PATH/python3 -m ray.scripts.scripts start --head --node-ip-address=${head_node_ip} --port=${RAY_PORT} --num-gpus=${GPUS_PER_NODE} --num-cpus=${SLURM_CPUS_PER_TASK} --block"
    echo "Starting Ray head on ${head_node} (${head_node_ip})"
    start_ray_node "$head_node" "$head_cmd"

    worker_count=$((NUM_NODES - 1))
    for ((i = 1; i < NUM_NODES; i++)); do
        node_i=${nodes_array[$i]}
        node_i_ip="${node_i}i" # for JSC
        this_node_ip="$(nslookup "$node_i_ip" | grep -oP '(?<=Address: ).*')"
        worker_cmd="$CONDA_PYTHON_PATH/python3 -m ray.scripts.scripts start --address ${ip_head} --node-ip-address="$this_node_ip" --num-gpus=${GPUS_PER_NODE} --num-cpus=${SLURM_CPUS_PER_TASK} --block"
        echo "Starting Ray worker on ${node_i}"
        start_ray_node "$node_i" "$worker_cmd"
        sleep 3
    done

    export LD_PRELOAD="$ORIG_LD_PRELOAD"

    cleanup() {
        echo "Cleaning up Ray cluster and vLLM controller..."
        # Stop health monitor if running
        if [ -n "${HEALTH_MONITOR_PID:-}" ]; then
            kill "$HEALTH_MONITOR_PID" >/dev/null 2>&1 || true
            wait "$HEALTH_MONITOR_PID" >/dev/null 2>&1 || true
        fi
        if [ -n "${VLLM_PID:-}" ]; then
            kill "$VLLM_PID" >/dev/null 2>&1 || true
            wait "$VLLM_PID" >/dev/null 2>&1 || true
        fi
        for node in "${nodes_array[@]}"; do
            srun --export="$SRUN_EXPORT_ENV" --nodes=1 --ntasks=1 -w "$node" ray stop --force >/dev/null 2>&1 || true
        done
        for pid in "${ray_pids[@]}"; do
            wait "$pid" >/dev/null 2>&1 || true
        done
    }
    trap cleanup EXIT

    echo "Waiting for Ray cluster resources..."
    $CONDA_PYTHON_PATH/python3 scripts/ray/wait_for_cluster.py \
        --address "$ip_head" \
        --expected-gpus "$TOTAL_GPUS" \
        --expected-nodes "$NUM_NODES" \
        --timeout 600 \
        --poll-interval 10

    echo "Launching vLLM Ray controller on ${head_node_ip}:${API_PORT}"
    controller_log="{experiments_dir}/logs/{job_name}_vllm.log"
    echo "Controller environment variables:"
    echo "  TRITON_CC=$TRITON_CC"
    echo "  TRITON_LIBCUDA_PATH=${TRITON_LIBCUDA_PATH:-<not set>}"
    echo "  LD_LIBRARY_PATH=$LD_LIBRARY_PATH"
    echo "  PATH=$PATH"
    echo "  HF_HOME=$HF_HOME"
    echo "  PYTHONPATH=$PYTHONPATH"

    # Build env command with optional TRITON_LIBCUDA_PATH
    CONTROLLER_ENV_CMD="env TRITON_CC=$TRITON_CC LD_LIBRARY_PATH=$LD_LIBRARY_PATH PATH=$PATH HF_HOME=$HF_HOME PYTHONPATH=$PYTHONPATH"
    if [ -n "${TRITON_LIBCUDA_PATH:-}" ]; then
        CONTROLLER_ENV_CMD="$CONTROLLER_ENV_CMD TRITON_LIBCUDA_PATH=$TRITON_LIBCUDA_PATH"
    fi

    $CONDA_PYTHON_PATH/python3 scripts/vllm/start_vllm_ray_controller.py \
            --ray-address "$ip_head" \
            --host "$head_node_ip" \
            --port "$API_PORT" \
            --endpoint-json "$ENDPOINT_JSON" \
            --tensor-parallel-size "$TP_SIZE" \
            --data-parallel-size "$DP_SIZE" \
            --model "$MODEL_PATH" \
        >> "$controller_log" 2>&1 &
    VLLM_PID=$!

    echo "vLLM controller PID: $VLLM_PID (log: $controller_log)"

    if [ "$REQUIRE_ENDPOINT" = "1" ] && [ "$WAIT_FOR_ENDPOINT" = "1" ]; then
        ENDPOINT_WAIT_TIMEOUT="${DATAGEN_ENDPOINT_WAIT_TIMEOUT:-180}"
        ENDPOINT_WAIT_INTERVAL="${DATAGEN_ENDPOINT_WAIT_INTERVAL:-5}"
        wait_elapsed=0

        while true; do
            if ! kill -0 "$VLLM_PID" 2>/dev/null; then
                wait "$VLLM_PID" || true
                echo "ERROR: vLLM controller exited before writing endpoint JSON; see $controller_log"
                exit 1
            fi

            if [ -f "$ENDPOINT_JSON" ]; then
                echo "✓ Endpoint JSON detected after ${wait_elapsed}s: $ENDPOINT_JSON"
                break
            fi

            if [ "$wait_elapsed" -ge "$ENDPOINT_WAIT_TIMEOUT" ]; then
                echo "ERROR: Endpoint JSON not found within ${ENDPOINT_WAIT_TIMEOUT}s (controller PID $VLLM_PID still running)"
                exit 1
            fi

            sleep "$ENDPOINT_WAIT_INTERVAL"
            wait_elapsed=$((wait_elapsed + ENDPOINT_WAIT_INTERVAL))
            if [ $((wait_elapsed % 30)) -eq 0 ]; then
                echo "Waiting for endpoint JSON... ${wait_elapsed}s elapsed"
            fi
        done

        echo "Waiting for vLLM endpoint to become healthy..."
        $CONDA_PYTHON_PATH/python3 -u scripts/vllm/wait_for_endpoint.py \
            --endpoint-json "$ENDPOINT_JSON" \
            --max-attempts "${DATAGEN_HEALTHCHECK_MAX_ATTEMPTS:-20}" \
            --retry-delay "${DATAGEN_HEALTHCHECK_RETRY_DELAY:-30}" \
            --health-path "v1/models"
    else
        echo "Skipping endpoint wait (backend=$BACKEND, wait_flag=$WAIT_FOR_ENDPOINT)"
        if ! kill -0 "$VLLM_PID" 2>/dev/null; then
            wait "$VLLM_PID" || true
            echo "ERROR: vLLM controller exited immediately; see $controller_log"
            exit 1
        fi
    fi

    setup_proxy

    # Start background Ray health monitor
    HEALTH_CHECK_INTERVAL="${DATAGEN_HEALTH_CHECK_INTERVAL:-60}"
    health_log="{experiments_dir}/logs/{job_name}_ray_health.log"
    echo "Starting background Ray health monitor (interval=${HEALTH_CHECK_INTERVAL}s, log: $health_log)"
    $CONDA_PYTHON_PATH/python3 scripts/ray/check_ray_health.py \
        --address "$RAY_ADDRESS" \
        --expected-nodes "$NUM_NODES" \
        --expected-gpus "$TOTAL_GPUS" \
        --continuous \
        --interval "$HEALTH_CHECK_INTERVAL" \
        --verbose \
        >> "$health_log" 2>&1 &
    HEALTH_MONITOR_PID=$!
    echo "Ray health monitor PID: $HEALTH_MONITOR_PID"

    run_datagen_stream
    EXIT_CODE=$?
fi

if [ $EXIT_CODE -eq 0 ]; then
    echo "======================================"
    echo "✓ Data generation completed successfully"
    echo "Target repo: $TARGET_REPO"
    echo "======================================"
else
    echo "======================================"
    echo "✗ Data generation failed with exit code: $EXIT_CODE"
    echo "======================================"
    exit $EXIT_CODE
fi
