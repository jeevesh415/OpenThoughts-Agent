# Placeholder template for DC-Agent secrets.
#
# Do NOT store real API keys in the repository. Instead, set the environment
# variable `DC_AGENT_SECRET_ENV` to point to a private env file outside of this
# repo that exports the required secrets (e.g., DAYTONA_API_KEY, HF_TOKEN,
# WANDB_API_KEY, SUPABASE_*).
#
# Example outside this repo:
#   export DAYTONA_API_KEY=...
#   export HF_TOKEN=...
#   export WANDB_API_KEY=...
#
# Then, before running any scripts, export:
#   export DC_AGENT_SECRET_ENV=/secure/path/to/my_dc_agent_secrets.env
#
# Scripts now look for DC_AGENT_SECRET_ENV and source it if present. This
# placeholder remains for documentation purposes only.
echo "[dc-agent] hpc/dotenv/secret.env is a placeholder. Set DC_AGENT_SECRET_ENV to your private secrets file." >&2 || true
